# OctoFit Tracker Frontend Environment Configuration

# API Base URL
# Use http://localhost:8000/api for local development
# For Codespaces, the backend will be available at the forwarded port
REACT_APP_API_URL=http://localhost:8000/api

# Optional: Codespace name (auto-detected in code if using GitHub Codespaces)
# REACT_APP_CODESPACE_NAME=your-codespace-name
